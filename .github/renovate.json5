{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
    ':semanticCommitTypeAll(chore)',
    ':timezone(Asia/Tokyo)',
  ],
  labels: ['dependencies'],
  minimumReleaseAge: '14 days',
  prConcurrentLimit: 5,
  branchConcurrentLimit: 5,
  prHourlyLimit: 5,
  dependencyDashboard: true,
  enabledManagers: [
    'gomod',
    'github-actions',
  ],
  postUpdateOptions: [
    'gomodTidy',
    'gomodUpdateImportPaths',
  ],
}
